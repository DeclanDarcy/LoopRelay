{
  "stream": "decision",
  "events": [
    {
      "type": "run-started",
      "phase": "DecisionRun",
      "route": "Continue"
    },
    {
      "type": "diagnostics",
      "sandbox": "read-only",
      "approvals": "never",
      "seeded": true
    },
    {
      "type": "phase",
      "phase": "GetNextDecisions"
    },
    {
      "type": "transferred",
      "operationalDelta": ".agents/operational_delta.md",
      "operationalContext": ".agents/operational_context.md"
    },
    {
      "type": "delta",
      "text": "Decision chunk."
    },
    {
      "type": "completed",
      "promptTokens": 10,
      "outputTokens": 20
    },
    {
      "type": "review-ready",
      "decisions": "PROPOSED DECISIONS"
    },
    {
      "type": "submitted",
      "path": ".agents/decisions/decisions.md",
      "sequence": 1,
      "numberedPath": ".agents/decisions/decisions.0001.md"
    },
    {
      "type": "failed",
      "phase": "GetNextDecisions",
      "reason": "The decision proposal run failed.",
      "detail": "boom"
    }
  ]
}