root = true

[*.cs]
indent_style = space
indent_size = 4

dotnet_naming_style.underscore_prefixed_camel_case.required_prefix = _
dotnet_naming_style.underscore_prefixed_camel_case.capitalization = camel_case

[src/**/Services/*.cs]
# EditorConfig cannot distinguish dependency-injected primary constructor
# parameters from ordinary method parameters. This scopes the closest
# enforceable convention to service files that use constructor injection.
dotnet_naming_rule.service_parameters_should_use_underscore.severity = suggestion
dotnet_naming_rule.service_parameters_should_use_underscore.symbols = service_parameters
dotnet_naming_rule.service_parameters_should_use_underscore.style = underscore_prefixed_camel_case

dotnet_naming_symbols.service_parameters.applicable_kinds = parameter

# Explicit-constructor services still use private readonly backing fields.
dotnet_naming_rule.private_readonly_fields_should_use_underscore.severity = suggestion
dotnet_naming_rule.private_readonly_fields_should_use_underscore.symbols = private_readonly_fields
dotnet_naming_rule.private_readonly_fields_should_use_underscore.style = underscore_prefixed_camel_case

dotnet_naming_symbols.private_readonly_fields.applicable_kinds = field
dotnet_naming_symbols.private_readonly_fields.applicable_accessibilities = private
dotnet_naming_symbols.private_readonly_fields.required_modifiers = readonly

[src/**/Services/**/*.cs]
# EditorConfig cannot distinguish dependency-injected primary constructor
# parameters from ordinary method parameters. This scopes the closest
# enforceable convention to service files that use constructor injection.
dotnet_naming_rule.service_parameters_should_use_underscore.severity = suggestion
dotnet_naming_rule.service_parameters_should_use_underscore.symbols = service_parameters
dotnet_naming_rule.service_parameters_should_use_underscore.style = underscore_prefixed_camel_case

dotnet_naming_symbols.service_parameters.applicable_kinds = parameter

# Explicit-constructor services still use private readonly backing fields.
dotnet_naming_rule.private_readonly_fields_should_use_underscore.severity = suggestion
dotnet_naming_rule.private_readonly_fields_should_use_underscore.symbols = private_readonly_fields
dotnet_naming_rule.private_readonly_fields_should_use_underscore.style = underscore_prefixed_camel_case

dotnet_naming_symbols.private_readonly_fields.applicable_kinds = field
dotnet_naming_symbols.private_readonly_fields.applicable_accessibilities = private
dotnet_naming_symbols.private_readonly_fields.required_modifiers = readonly
